# App
SPRING_PROFILES_ACTIVE=dev
PORT=8080
PROVISIONING_WORKER_ENABLED=true
PROVISIONING_DRY_RUN=false

# Auth
JWT_SECRET=replace-with-a-secure-base64-encoded-key-at-least-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Database (Supabase PostgreSQL — reSession Pooler)
DATABASE_URL=jdbc:postgresql://<db-host>:5432/postgres

# Redis (cache / token storage)
REDIS_HOST=<cache-redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=<cache-redis-password>
REDIS_TLS=true

# Redis (queue)
# Use a dedicated Redis for queue workloads.
QUEUE_REDIS_HOST=<queue-redis-host>
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=<queue-redis-password>
QUEUE_REDIS_TLS=true

# Optional Upstash REST values (only if used elsewhere)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Contabo OAuth2
CONTABO_CLIENT_ID=<contabo-client-id>
CONTABO_CLIENT_SECRET=<contabo-client-secret>
CONTABO_API_USER=<contabo-api-user>
CONTABO_API_PASSWORD=<contabo-api-password>
CONTABO_API_URL=https://api.contabo.com

# Stripe
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
STRIPE_ENABLED=true

# Facebook Conversions API
FACEBOOK_PIXEL_ID=<facebook-pixel-id>
FACEBOOK_ACCESS_TOKEN=<facebook-access-token>
FACEBOOK_TEST_EVENT_CODE=

# Telegram Bot (monitoring alerts)
TELEGRAM_BOT_TOKEN=<telegram-bot-token>

# SMTP (Purelymail)
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=465
SMTP_USER=support@valoracloud.com
SMTP_PASS=<smtp-password>
SMTP_FROM=support@valoracloud.com

# Branding
BRAND_NAME=Valora Cloud
BRAND_DOMAIN=valoracloud.com

# Security
ENCRYPTION_KEY=<64-hex-chars>

# SHKeeper (crypto payments)
SHKEEPER_ENABLED=false
SHKEEPER_BASE_URL=https://gateway.valoracloud.com
SHKEEPER_API_KEY=<shkeeper-api-key>

# Frontend
FRONTEND_URL=https://valoracloud.com

# URLs
APP_URL=https://api.valoracloud.com

# Whois Privacy Protection
WHOIS_PRIVACY_HANDLE_ID=
WHOIS_PRIVACY_PRICE=2.99
