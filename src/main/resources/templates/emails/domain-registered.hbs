{{> header}}
  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{domain_registered_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{domain_registered_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;"><p class="body">{{domain_registered_body}}</p></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{domain_registered_details_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{domain_registered_details_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{domain_registered_field_domain}}</td><td>{{domainName}}</td></tr>
      <tr><td class="field-label">{{domain_registered_field_expires}}</td><td>{{expiresAt}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <div class="info-soft">
      <p class="muted" style="font-size:12px;">{{domain_registered_tip}}</p>
    </div>
  </td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="{{frontendUrl}}/dashboard/domains" target="_blank">{{domain_registered_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
{{> footer}}
