{{> partials/header}}

  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{new_login_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{new_login_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;"><p class="body">{{new_login_body}} <span class="mono-val">{{to}}</span>. {{new_login_body_suffix}}</p></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{new_login_details_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{new_login_details_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{new_login_field_signed_in_at}}</td><td>{{signedInAt}}</td></tr>
      <tr><td class="field-label">{{new_login_field_ip}}</td><td>{{fromIp}}</td></tr>
      <tr><td class="field-label">{{new_login_field_location}}</td><td>{{location}}</td></tr>
      <tr><td class="field-label">{{new_login_field_device}}</td><td>{{device}}</td></tr>
      <tr><td class="field-label">{{new_login_field_auth_method}}</td><td>{{authMethod}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;">
    <div class="alert-soft">
      <p class="body" style="font-size:13px;font-weight:500;margin-bottom:4px;">{{new_login_alert_title}}</p>
      <p class="muted" style="font-size:12px;">{{new_login_alert_body}}</p>
    </div>
  </td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="{{frontendUrl}}/dashboard/security/sessions" target="_blank">{{new_login_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
{{> partials/footer}}

