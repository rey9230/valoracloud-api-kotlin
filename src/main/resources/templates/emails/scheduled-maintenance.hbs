{{> header}}
  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow-mute">{{maintenance_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{maintenance_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;"><p class="body">{{maintenance_body}}</p></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{maintenance_window_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{maintenance_window_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{maintenance_field_region}}</td><td>{{region}}</td></tr>
      <tr><td class="field-label">{{maintenance_field_window}}</td><td>{{window}}</td></tr>
      <tr><td class="field-label">{{maintenance_field_local_time}}</td><td>{{localTime}}</td></tr>
      <tr><td class="field-label">{{maintenance_field_duration}}</td><td>{{duration}}</td></tr>
      <tr><td class="field-label">{{maintenance_field_impact}}</td><td>{{impact}}</td></tr>
      <tr><td class="field-label">{{maintenance_field_reference}}</td><td>{{reference}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{maintenance_affected_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{maintenance_affected_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;"><p class="body">{{maintenance_affected_body}}</p></td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="https://status.{{brandDomain}}/maintenance/{{reference}}" target="_blank">{{maintenance_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 32px 40px;">
    <p class="body" style="margin-bottom:14px;">{{maintenance_closing}}</p>
    <p class="body" style="font-weight:500;">{{team_sign}}</p>
  </td></tr>
{{> footer}}
