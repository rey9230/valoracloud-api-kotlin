{{> partials/header}}

  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{object_storage_ready_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{object_storage_ready_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;"><p class="body">{{object_storage_ready_body}}</p></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{object_storage_ready_details_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{object_storage_ready_details_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{object_storage_ready_field_name}}</td><td>{{displayName}}</td></tr>
      <tr><td class="field-label">{{object_storage_ready_field_region}}</td><td>{{region}}</td></tr>
      <tr><td class="field-label">{{object_storage_ready_field_endpoint}}</td><td>{{s3Endpoint}}</td></tr>
      <tr><td class="field-label">{{object_storage_ready_field_access_key}}</td><td>{{accessKey}}</td></tr>
      <tr><td class="field-label">{{object_storage_ready_field_secret_key}}</td><td>{{secretKey}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <div class="info-soft">
      <p class="muted" style="font-size:12px;">{{object_storage_ready_tip}}</p>
    </div>
  </td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="{{frontendUrl}}/dashboard/storage" target="_blank">{{object_storage_ready_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
{{> partials/footer}}

