{{> header}}
  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{server_ready_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{server_ready_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;"><p class="body">{{server_ready_body}}</p></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{server_ready_details_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{server_ready_details_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 8px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{server_ready_field_ip}}</td><td>{{ipAddress}}</td></tr>
      <tr><td class="field-label">{{server_ready_field_hostname}}</td><td>{{hostname}}</td></tr>
      <tr><td class="field-label">{{server_ready_field_username}}</td><td>{{username}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:20px 40px 8px 40px;"><p class="body">{{server_ready_connect_body}}</p></td></tr>
  <tr><td class="pad-x" style="padding:16px 40px 24px 40px;">
    <div class="terminal">
      <span class="term-mute"># {{server_ready_connect_comment}}</span><br/>
      <span class="term-prompt">$</span> ssh {{username}}@{{ipAddress}}
    </div>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <div class="warn-soft">
      <p class="body" style="font-size:13px;font-weight:500;margin-bottom:4px;">{{server_ready_warning}}</p>
      <p class="muted" style="font-size:12px;">{{server_ready_warning_body}}</p>
    </div>
  </td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="{{frontendUrl}}/dashboard/servers" target="_blank">{{server_ready_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
{{> footer}}
