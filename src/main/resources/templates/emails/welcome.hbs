{{> header}}
  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{welcome_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{welcome_headline}}<br/>{{brandName}}.</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;"><p class="body">{{welcome_body}}</p></td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 16px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="{{verifyUrl}}" target="_blank">{{welcome_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 36px 40px;">
    <p class="muted" style="margin-bottom:6px;">{{welcome_link_label}}</p>
    <p class="mono-val" style="word-break:break-all;font-size:11.5px;color:#6B7280;">{{verifyUrl}}</p>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{welcome_steps_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{welcome_steps_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr><td class="timeline-step">
        <span class="mono-val" style="color:#B83232;font-weight:500;">01</span>&nbsp;&nbsp;
        <span class="body" style="font-weight:500;">{{welcome_step1_title}}</span><br/>
        <span class="muted" style="margin-left:32px;display:inline-block;margin-top:4px;">{{welcome_step1_body}}</span>
      </td></tr>
      <tr><td class="timeline-step">
        <span class="mono-val" style="color:#B83232;font-weight:500;">02</span>&nbsp;&nbsp;
        <span class="body" style="font-weight:500;">{{welcome_step2_title}}</span><br/>
        <span class="muted" style="margin-left:32px;display:inline-block;margin-top:4px;">{{welcome_step2_body}}</span>
      </td></tr>
      <tr><td class="timeline-step">
        <span class="mono-val" style="color:#B83232;font-weight:500;">03</span>&nbsp;&nbsp;
        <span class="body" style="font-weight:500;">{{welcome_step3_title}}</span><br/>
        <span class="muted" style="margin-left:32px;display:inline-block;margin-top:4px;">{{welcome_step3_body}}</span>
      </td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 32px 40px;">
    <p class="muted" style="font-size:12px;margin-bottom:14px;">{{welcome_ignore}}</p>
    <p class="body" style="font-weight:500;">{{welcome_team}}</p>
  </td></tr>
{{> footer}}
