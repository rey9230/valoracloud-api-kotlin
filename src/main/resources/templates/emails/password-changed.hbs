{{> header}}
  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{password_changed_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{password_changed_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;"><p class="body">{{password_changed_body}}</p></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{password_changed_details_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{password_changed_details_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{password_changed_field_changed_at}}</td><td>{{changedAt}}</td></tr>
      <tr><td class="field-label">{{password_changed_field_ip}}</td><td>{{fromIp}}</td></tr>
      <tr><td class="field-label">{{password_changed_field_location}}</td><td>{{location}}</td></tr>
      <tr><td class="field-label">{{password_changed_field_device}}</td><td>{{device}}</td></tr>
      <tr><td class="field-label">{{password_changed_field_account}}</td><td>{{to}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <div class="alert-soft">
      <p class="body" style="font-size:13px;font-weight:500;margin-bottom:4px;">{{password_changed_alert_title}}</p>
      <p class="muted" style="font-size:12px;">{{password_changed_alert_body}}</p>
    </div>
  </td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#B83232;border-radius:8px;">
        <a class="btn-danger" href="{{frontendUrl}}/dashboard/security" target="_blank">{{password_changed_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
{{> footer}}
