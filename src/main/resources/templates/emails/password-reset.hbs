{{> header}}
  <tr><td class="pad-x" style="padding:40px 40px 8px 40px;"><div class="eyebrow">{{password_reset_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:14px 40px 16px 40px;"><h1 class="editorial">{{password_reset_headline}}</h1></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;"><p class="body">{{password_reset_body}} <span class="mono-val">{{to}}</span>. {{password_reset_expiry}}</p></td></tr>
  <tr><td class="pad-x" align="left" style="padding:0 40px 36px 40px;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
      <td align="center" style="background:#0D1F4E;border-radius:8px;">
        <a class="btn" href="{{resetUrl}}" target="_blank">{{password_reset_cta}}</a>
      </td>
    </tr></table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 24px 40px;">
    <p class="muted" style="margin-bottom:8px;">{{password_reset_link_label}}</p>
    <p class="mono-val" style="word-break:break-all;font-size:11.5px;color:#6B7280;">{{resetUrl}}</p>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 0 40px;"><div class="hairline-strong"></div></td></tr>
  <tr><td class="pad-x" style="padding:32px 40px 4px 40px;"><div class="eyebrow">{{password_reset_details_eyebrow}}</div></td></tr>
  <tr><td class="pad-x" style="padding:12px 40px 16px 40px;"><h2 class="section-title">{{password_reset_details_title}}</h2></td></tr>
  <tr><td class="pad-x" style="padding:0 40px 28px 40px;">
    <table role="presentation" class="data" cellpadding="0" cellspacing="0" border="0">
      <tr><th style="width:36%;">{{th_field}}</th><th>{{th_value}}</th></tr>
      <tr><td class="field-label">{{password_reset_field_requested_at}}</td><td>{{requestedAt}}</td></tr>
      <tr><td class="field-label">{{password_reset_field_ip}}</td><td>{{fromIp}}</td></tr>
      <tr><td class="field-label">{{password_reset_field_location}}</td><td>{{location}}</td></tr>
      <tr><td class="field-label">{{password_reset_field_device}}</td><td>{{device}}</td></tr>
    </table>
  </td></tr>
  <tr><td class="pad-x" style="padding:0 40px 32px 40px;">
    <div class="alert-soft">
      <p class="body" style="font-size:13px;font-weight:500;margin-bottom:4px;">{{password_reset_alert_title}}</p>
      <p class="muted" style="font-size:12px;">{{password_reset_alert_body}}</p>
    </div>
  </td></tr>
{{> footer}}
